# Copier ce fichier vers .env (dans le dossier docker/) puis renseigner les valeurs.
# Le fichier .env ne doit PAS être commité : il est ignoré par .gitignore.

# Clé publique SSH autorisée à se connecter au conteneur jenkins-agent.
# C'est la partie publique de la paire de clés dont la clé PRIVÉE est stockée
# dans les credentials Jenkins (utilisée par le nœud agent-linux).
# ssh-keygen -t rsa -b 4096 -f jenkins_agent_key
# Exemple : ssh-rsa AAAAB3NzaC1yc2E... jenkins
JENKINS_AGENT_SSH_PUBKEY=
